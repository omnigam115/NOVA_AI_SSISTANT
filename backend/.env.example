# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- General ---
APP_NAME=NOVA AI Assistant
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# --- Database ---
# Local development defaults to SQLite so the project can run without a running Postgres service.
# For container-based development you can switch these values back to Postgres.
DATABASE_URL=sqlite+aiosqlite:///./nova.db
DATABASE_URL_SYNC=sqlite:///./nova.db

# --- JWT Authentication ---
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Logging ---
LOG_LEVEL=INFO

# --- Postgres container credentials (used by docker-compose) ---
POSTGRES_USER=nova_user
POSTGRES_PASSWORD=nova_password
POSTGRES_DB=nova_db
